# Supabase project settings (Project Settings > API in the Supabase dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: Google OAuth client id for native social login (see README)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Used only by `npm run seed` (never bundled into the app). Service role key
# is in Project Settings > API > service_role — keep it secret, server-side only.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
